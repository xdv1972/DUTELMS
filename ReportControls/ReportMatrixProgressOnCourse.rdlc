                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=iif(isNothing(Fields!P_Score.Value),"", CStr(Fields!P_Score.Value) + Chr(13) + Chr(10)+ "  " + CStr(String.Format("{0:dd.MM.yyyy}",Fields!CreateDate.Value)) + Chr(13) + Chr(10)+ " " + iif(Fields!P_State.Value=3, "+", "*"))</Value>
