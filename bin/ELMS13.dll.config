<?xml version="1.0"?>
<configuration>
  <appSettings>
    <add key="UploadPath" value="upload\"/>
    <add key="UploadMailPath" value="upload\mail\"/>
    <add key="CoursePath" value="Courses\"/>
    <add key="AdobeFlashTrackPath" value="http://localhost:1145/ELMS/StudentHome/wsElmsTrack.asmx?WSDL"/>
    <add key="AdobeFlashTrackMethod" value="SendGet"/>
    <add key="LogEvents" value="false"/>
    <add key="LogExceptions" value="false"/>
    <add key="ContactAdminName" value="Адміністратори: ------------"/>
    <add key="ContactPhone" value="Служба підтримки: тел. (---) ###-##-##"/>
    <add key="SmtpFrom" value="elearninggroup@ukrtelecom.ua"/>
    <add key="SmtpServer" value="https://webmail.ukrtelecom.net"/>
    <add key="SmtpLogin" value="SmtpLogin"/>
    <add key="SmtpPassword" value="SmtpPassword"/>
    <add key="attemptsCount" value="0"/>
    <add key="LDAPConnectionString" value="LDAP://corp.ukrtelecom.loc/DC=corp,DC=ukrtelecom,DC=loc"/>
    <add key="AdUser" value="corp\apadalka"/>
    <add key="AdPassword" value="apadalka+++"/>
  </appSettings>
  <connectionStrings>
    <add name="OTINSConnection" connectionString="Data Source=DL7\MSSQLSERVER2008;Initial Catalog=otins6_dev;User ID=sa;Password=ntsnerver" providerName="System.Data.SqlClient"/>
    <!--<add name="ELMS_2013ConnectionString" connectionString="Data Source=ARTEMIS-PC\SQLEXPRESS;Initial Catalog=ELMS_2013;Integrated security=true" providerName="System.Data.SqlClient"/>-->
    <add name="ELMS_2013ConnectionString" connectionString="Data Source=DLX-HM1;Initial Catalog=DELMS_2014;User ID=sa;Password=SQL_Admin" providerName="System.Data.SqlClient"/>
    <!--<add name="ELMS_2013ConnectionString" connectionString="Data Source=KV-SC-SQL-S001;Initial Catalog=ELMS_2013;User ID=sa;Password=SQL_Admin" providerName="System.Data.SqlClient"/>-->
  </connectionStrings>
  <system.web>
    <trust legacyCasModel="true" level="Full"/>
    <httpRuntime maxRequestLength="100000"/>
    <machineKey validationKey="B8DAF7203AA5E377D908AAED78B0F0288B4343F5" decryptionKey="5484E85CF290ACF1FCFE3C1440D29D36F159AEDF79E81FB3" decryption="3DES" validation="SHA1"/>
    <customErrors defaultRedirect="GenericError.htm" mode="Off">
      <error statusCode="500" redirect="InternalError.htm"/>
      <error statusCode="404" redirect="InternalError.htm"/>
    </customErrors>
    <anonymousIdentification enabled="true" cookieName=".ASPXANONYMOUS" cookieTimeout="43200" cookiePath="/" cookieRequireSSL="false" cookieSlidingExpiration="true" cookieProtection="All" cookieless="UseDeviceProfile"/>
    <profile enabled="true" defaultProvider="ELMSProfileSqlProvider">
      <providers>
        <add name="ELMSProfileSqlProvider" type="System.Web.Profile.SqlProfileProvider, System.Web, Version=2.0.3600.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" connectionStringName="ELMS_2013ConnectionString" applicationName="ELMSWebPortal"/>
      </providers>
      <properties>
        <add name="FirstName" type="System.String"/>
        <add name="LastName" type="System.String"/>
        <add name="MiddleName" type="System.String"/>
      </properties>
    </profile>
    <membership defaultProvider="ELMSMemSqlProvider" userIsOnlineTimeWindow="15">
      <providers>
        <add name="ELMSMemSqlProvider" type="System.Web.Security.SqlMembershipProvider, System.Web, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" connectionStringName="ELMS_2013ConnectionString" enablePasswordRetrieval="true" enablePasswordReset="true" requiresQuestionAndAnswer="false" applicationName="ELMSWebPortal" requiresUniqueEmail="true" passwordFormat="Encrypted" minRequiredNonalphanumericCharacters="0" maxInvalidPasswordAttempts="100" passwordAttemptWindow="30"/>
      </providers>
    </membership>
    <roleManager enabled="true" defaultProvider="ELMS13RoleProvider" cookieTimeout="30" cookiePath="/" cookieRequireSSL="false" cookieSlidingExpiration="true" cookieProtection="All">
      <providers>
        <add name="ELMSRoleProvider" type="System.Web.Security.SqlRoleProvider" connectionStringName="ELMS_2013ConnectionString" applicationName="ELMSWebPortal"/>
        <add name="ELMS13RoleProvider" type="ELMS13.DATA.ElmsRoleProvider" connectionStringName="ELMS_2013ConnectionString" applicationName="ELMSWebPortal"/>
      </providers>
    </roleManager>
    <globalization requestEncoding="utf-8" responseEncoding="utf-8"/>
    <authorization>
      <allow users="*"/>
    </authorization>
    <siteMap defaultProvider="XmlSiteMapProvider" enabled="true">
      <providers>
        <add name="XmlSiteMapProvider" description="SiteMap provider which reads in .sitemap XML files." type="System.Web.XmlSiteMapProvider, System.Web, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" siteMapFile="web.sitemap" securityTrimmingEnabled="true"/>
      </providers>
    </siteMap>
    <!--
            The <authentication> section enables configuration 
            of the security authentication mode used by 
            ASP.NET to identify an incoming user. 
        -->
    <authentication mode="Forms">
      <forms loginUrl="~/elmsLogin.aspx" protection="Encryption" timeout="60" />
    </authentication>
    <!-- 
            Set compilation debug="true" to insert debugging 
            symbols into the compiled page. Because this 
            affects performance, set this value to true only 
            during development.
        -->
    <compilation debug="true" targetFramework="4.0">
      <assemblies>
        <!--<add assembly="Microsoft.ReportViewer.WebForms, Version=9.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A" />-->
        <!--<add assembly="Microsoft.ReportViewer.Common, Version=9.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A" />-->
        <add assembly="Microsoft.ReportViewer.Common, Version=10.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A"/>
        <add assembly="Microsoft.ReportViewer.WebForms, Version=10.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A"/>
        <add assembly="System.Web.Extensions.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35"/>
        <add assembly="System.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A"/>
        <add assembly="System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B77A5C561934E089"/>
        <!--<add assembly="Microsoft.ReportViewer.WebForms, Version=11.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91"/>
        <add assembly="Microsoft.ReportViewer.Common, Version=11.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91"/>-->
        <add assembly="Microsoft.Build.Framework, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A"/>
      </assemblies>
      <buildProviders>
        <add extension=".rdlc" type="Microsoft.Reporting.RdlBuildProvider, Microsoft.ReportViewer.WebForms, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a"/>
      </buildProviders>
    </compilation>
    <!--
            The <customErrors> section enables configuration 
            of what to do if/when an unhandled error occurs 
            during the execution of a request. Specifically, 
            it enables developers to configure html error pages 
            to be displayed in place of a error stack trace.

        <customErrors mode="RemoteOnly" defaultRedirect="GenericErrorPage.htm">
            <error statusCode="403" redirect="NoAccess.htm" />
            <error statusCode="404" redirect="FileNotFound.htm" />
        </customErrors>
        -->
    <pages theme="ut" controlRenderingCompatibilityVersion="4.0" clientIDMode="AutoID"/>
    <httpHandlers>
      <add path="Reserved.ReportViewerWebControl.axd" verb="*" type="Microsoft.Reporting.WebForms.HttpHandler, Microsoft.ReportViewer.WebForms, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" validate="false"/>
    </httpHandlers>
    <identity impersonate="false"/>
  </system.web>
  <!-- 
        The system.webServer section is required for running ASP.NET AJAX under Internet
        Information Services 7.0.  It is not necessary for previous version of IIS.
    -->
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="100000000"/>
      </requestFiltering>
    </security>
    <validation validateIntegratedModeConfiguration="false"/>
    <handlers>
      <add name="ReportViewerWebControlHandler" preCondition="integratedMode" verb="*" path="Reserved.ReportViewerWebControl.axd" type="Microsoft.Reporting.WebForms.HttpHandler, Microsoft.ReportViewer.WebForms, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a"/>
    </handlers>
  </system.webServer>
  <system.net>
    <mailSettings>
      <smtp from="admin@gmail.com">
        <network host="10.34.15.2" port="25" userName="" password=""/>
      </smtp>
    </mailSettings>
  </system.net>
  <location path="StudentHome">
    <system.web>
      <httpRuntime requestValidationMode="2.0"/>
      <authorization>
        <allow roles="Student"/>
        <deny users="*"/>
      </authorization>
    </system.web>
  </location>
  <location path="AdminHome">
    <system.web>
      <httpRuntime requestValidationMode="2.0"/>
      <authorization>
        <allow roles="Administrator"/>
        <deny users="*"/>
      </authorization>
    </system.web>
  </location>
  <location path="TeacherHome">
    <system.web>
      <httpRuntime requestValidationMode="2.0"/>
      <authorization>
        <allow roles="teacher"/>
        <deny users="*"/>
      </authorization>
    </system.web>
  </location>
  <location path="MethodistHome">
    <system.web>
      <httpRuntime requestValidationMode="2.0"/>
      <authorization>
        <allow roles="Methodist"/>
        <deny users="*"/>
      </authorization>
    </system.web>
  </location>
</configuration>